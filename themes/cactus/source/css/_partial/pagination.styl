// Marginalia pagination — minimal mono line

.pagination
  margin: 48px 0 0
  display: flex
  justify-content: space-between
  align-items: center
  font-family: $font-family-mono
  font-size: 12px
  letter-spacing: .04em
  color: $fg-muted
  width: 100%

  .page-number
    color: $fg-muted
    font-size: 12px

  a
    color: $paper-800
    background-image: none
    text-decoration: none
    padding: 0

  a:hover
    color: $sage-500
    background-image: none
