// Marginalia footer — single muted mono line

#footer
  margin-top: 96px
  padding-top: 20px
  border-top: 1px solid $paper-200
  font-family: $font-family-mono
  font-size: 11px
  letter-spacing: .04em
  color: $fg-muted
  display: flex
  justify-content: space-between
  align-items: baseline
  width: 100%

  a
    color: $fg-muted
    background: none
    text-decoration: none

  a:hover
    color: $sage-500
    background: none

  ul
    margin: 0
    padding: 0
    list-style: none

  li
    display: inline-block
    border: none
    margin: 0

@media screen and (max-width: 480px)
  #footer
    flex-direction: column
    gap: 8px
