// Marginalia — article / post page

article.post
  max-width: 640px

  header
    .posttitle
      font-family: $font-family-body
      font-weight: 300
      font-size: 48px
      line-height: 1.1
      letter-spacing: -.02em
      color: $paper-900
      margin: 0 0 16px
      text-wrap: balance

    .meta
      font-family: $font-family-mono
      font-size: 11px
      letter-spacing: .06em
      color: $fg-muted
      text-transform: uppercase
      margin-bottom: 48px
      margin-top: 0

    .meta *
      color: $fg-muted
      font-size: 11px

    .author
      text-transform: uppercase
      letter-spacing: .06em
      font-weight: 400

    .postdate
      display: inline

  // Breadcrumb
  .m-crumb
    font-family: $font-family-mono
    font-size: 11px
    letter-spacing: .06em
    color: $fg-muted
    text-transform: uppercase
    margin-bottom: 64px

    a
      color: $paper-800
      background: none
      text-decoration: none

    a:hover
      color: $sage-500

    .sep
      margin: 0 10px
      color: $paper-300

  .content
    h2
      font-family: $font-family-body
      font-weight: 500
      font-size: 22px
      letter-spacing: -.005em
      color: $paper-900
      margin: 2.2em 0 .5em
      position: static

      &:before
        content: none

    h3
      font-family: $font-family-body
      font-weight: 500
      font-size: 20px
      letter-spacing: -.005em
      color: $paper-900
      margin: 2.2em 0 .5em

    p
      font-family: $font-family-body
      font-size: 17px
      line-height: 1.8
      color: $paper-800
      margin: 0 0 1em
      text-align: justify
      hyphens: auto

    blockquote
      margin: 32px 0
      padding: 0 0 0 24px
      border-left: 1px solid $paper-400
      background: inherit
      font-family: $font-family-body
      font-weight: 300
      font-style: italic
      font-size: 21px
      line-height: 1.45
      color: $paper-800
      text-align: left
      quotes: none

      &:before
        content: none

      p
        font-size: inherit
        line-height: inherit
        text-align: left
        margin: 0

    img
    video
      display: block
      margin: auto
      max-width: 100%
      max-height: 400px
      height: auto

    pre
      font-family: $font-family-mono
      font-size: 12px
      background: transparent
      border: none
      border-left: 1px solid $paper-300
      border-radius: 0
      padding: 4px 0 4px 16px
      white-space: pre-wrap
      color: $paper-800
      margin: 24px 0
      line-height: 1.6

    code
      font-family: $font-family-mono
      font-size: 13px
      padding: 0 4px
      border: 1px dotted $paper-200
      border-radius: 2px

  // Tag row at bottom of post
  .m-tag-row
    margin-top: 56px
    padding-top: 24px
    border-top: 1px solid $paper-200
    display: flex
    gap: 16px
    flex-wrap: wrap
    font-size: 13px

  .m-tag-row .chip
    font-family: $font-family-mono
    font-size: 12px
    color: $fg-muted
    background: none

    &::before
      content: "#"
      color: $sage-500
      margin-right: 1px

    a
      color: $fg-muted
      background: none
      text-decoration: none

    a:hover
      color: $sage-500

  // Article tags / category
  .article-tag .tag-link
    &:before
      content: "#"
    background: none
    color: $fg-muted
    font-family: $font-family-mono
    font-size: 12px

  .article-category .category-link
    background: none
    color: $fg-muted
    font-family: $font-family-mono
    font-size: 12px

.posttitle
  font-weight: 300
  font-size: 48px
  line-height: 1.1
  letter-spacing: -.02em

@media screen and (max-width: 640px)
  article.post
    max-width: 100%

    header .posttitle
      font-size: 32px
