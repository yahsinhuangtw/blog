// Marginalia header — wordmark + minimal nav

#header
  display: flex
  justify-content: space-between
  align-items: center
  padding-bottom: 24px
  border-bottom: 1px solid $paper-200
  margin-bottom: 80px
  width: 100%

  a
    background: none
    text-decoration: none

  .wordmark
    font-family: $font-family-display
    font-style: italic
    font-weight: 300
    font-size: 28px
    color: $paper-900
    line-height: 1
    letter-spacing: -.01em

  #title
    a
      background: none
      color: inherit

  #nav
    color: $paper-700
    font-size: 13px
    letter-spacing: .02em
    font-weight: 400

    ul
      margin: 0
      padding: 0
      list-style-type: none
      display: flex
      gap: 28px
      line-height: 1

      li
        display: inline-flex
        align-items: center
        margin: 0
        border: none

      .icon
        display: none

      a
        color: $paper-700
        background: none
        text-decoration: none
        position: relative

      a.active
        color: $paper-900
        font-weight: 500

      a.active::after
        content: ""
        position: absolute
        left: 0
        right: 0
        bottom: -6px
        height: 1px
        background: $sage-500

      a:hover
        color: $paper-900
        background: none

@media screen and (max-width: 640px)
  #header
    flex-direction: column
    align-items: flex-start
    gap: 16px
    margin-bottom: 48px

  #header #nav
    ul
      gap: 20px

    ul .icon
      display: none

    ul li
      display: inline-flex
