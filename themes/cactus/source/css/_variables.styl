// Fonts
$font-family-body    = "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif
$font-family-mono    = "JetBrains Mono", "Meslo LG", "Menlo", "Consolas", monospace
$font-family-display = "Newsreader", "Spectral", "Iowan Old Style", Georgia, serif
$font-family-tt      = "JetBrains Mono", monospace
$font-size           = 14px
$line-height         = 1.725
$page-width          = 0rem + (hexo-config("page_width") || 57)
// Logo
$logo-width   = 0px + (hexo-config("logo.width") || 0)
$logo-height  = 0px + (hexo-config("logo.height") || 0)
// Colors
$colors = hexo-config("colorscheme") || "light"
