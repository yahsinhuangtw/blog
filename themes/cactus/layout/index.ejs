<section class="m-intro">
  <p class="m-intro-text">
    Notes on developer communities, open-source conferences, technological innovation, language learning (French, Japanese, a little German), literary fiction, European history and politics, music, and culture.
  </p>
</section>

<% var topTags = site.tags.sort('length', -1).limit(12) %>
<% if (topTags.length) { %>
<div class="m-topics">
  <% topTags.each(function(tag){ %>
    <%
      var cls = '';
      if (tag.length >= 4) cls = 'lg';
      else if (tag.length >= 2) cls = 'md';
    %>
    <a href="<%- url_for(tag.path) %>" class="t <%= cls %>"><%= tag.name %><span class="ct"><%= tag.length %></span></a>
  <% }) %>
</div>
<% } %>

<% var field_sort = theme.posts_overview.sort_updated ? 'updated' : 'date' %>
<% if (theme.posts_overview.show_all_posts) { %>
  <% var show_posts = page.posts.sort(field_sort, 'desc') %>
<% } else { %>
  <% var show_posts = site.posts.sort(field_sort, 'desc').limit(theme.posts_overview.post_count || 5) %>
<% } %>

<% show_posts.each(function(post){ %>
  <%
    var d = post.date;
    var dayNum   = d.date();
    var monthStr = d.format('MMM').toLowerCase();
    var yearNum  = d.year();
    var months   = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
  %>
  <article class="m-entry">
    <div class="scaffold">
      <div class="day"><%= dayNum %></div>
      <div class="mo"><%= monthStr %></div>
      <div class="yr"><%= yearNum %></div>
    </div>
    <div class="body">
      <div class="kind-row">
        <% if (post.categories && post.categories.length) { %>
          <span class="kind"><%= post.categories.toArray()[0].name %></span>
          <span class="sep">·</span>
        <% } %>
        <span><%= post.date.format('MMMM D, YYYY') %></span>
      </div>
      <h2><a href="<%- url_for(post.path) %>"><%- post.title %></a></h2>
      <% if (post.excerpt) { %>
        <p class="dek"><%- post.excerpt.replace(/<[^>]+>/g, '').substring(0, 200) %></p>
      <% } %>
      <div class="entry-meta">
        <% post.tags.each(function(tag){ %>#<%= tag.name %>&nbsp;&nbsp;<% }) %>
      </div>
    </div>
  </article>
<% }) %>

<% if (theme.posts_overview.show_all_posts) { %>
  <%- partial('_partial/pagination') %>
<% } %>
